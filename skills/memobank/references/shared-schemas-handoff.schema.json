{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Handoff Envelope",
  "type": "object",
  "required": [
    "handoff_id",
    "scope",
    "return_contract"
  ],
  "properties": {
    "handoff_id": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "return_contract": {
      "type": "object"
    },
    "owned_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocking_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
